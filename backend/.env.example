# IronVault Environment Configuration
# =====================================

# Generate a secure secret key for JWT (use a strong random string in production)
SECRET_KEY=your-secret-key-here-change-this

# Email Configuration for OTP
# ===========================
# For Gmail, you need to:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use your Gmail address as MAIL_USERNAME
# 4. Use the 16-character App Password as MAIL_PASSWORD (no spaces)

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
